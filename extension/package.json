{
  "name": "captureinsight-extension",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/generate-icons.js",
    "build": "vite build && npm run postbuild",
    "postbuild": "cp manifest.json dist-extension/ && cp -r public/icons dist-extension/ && cp src/content/styles.css dist-extension/content/",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "typescript": "^5.5.0",
    "vite": "^6.3.5"
  }
}
